{
  "name": "java-migration-accelerator-backend",
  "version": 2,
  "builds": [
    {
      "src": "java-migration-backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "java-migration-backend/main.py"
    }
  ],
  "env": {
    "PYTHONPATH": "java-migration-backend"
  }
}